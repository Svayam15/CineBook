generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

///////////////////////
// ENUMS
///////////////////////

enum SeatStatus {
  AVAILABLE
  LOCKED
  BOOKED
}

enum SeatType {
  REGULAR
  GOLDEN
}

enum BookingStatus {
  PENDING
  PAID
  CANCELLED
  FAILED
}

enum PaymentType {
  CASH
  CARD
}

enum Role {
  USER
  ADMIN
}

enum OTPType {
  SIGNUP
  LOGIN
  FORGOT_PASSWORD
}

///////////////////////
// MODELS
///////////////////////

model User {
  id        Int      @id @default(autoincrement())
  name      String
  surname   String
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  bookings Booking[]
}

model OTP {
  id           Int       @id @default(autoincrement())
  email        String
  otp          String
  type         OTPType
  expiresAt    DateTime
  used         Boolean   @default(false)
  attempts     Int       @default(0)
  resendCount  Int       @default(0)
  blockedUntil DateTime?
  userData     Json?
  createdAt    DateTime  @default(now())

  @@index([email, type, used])
}

model LoginAttempt {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  attempts     Int       @default(0)
  blockedUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Movie {
  id        Int      @id @default(autoincrement())
  title     String
  duration  Int
  createdAt DateTime @default(now())
  isDeleted Boolean  @default(false)

  shows Show[]
}

model Theatre {
  id       Int    @id @default(autoincrement())
  name     String
  location String

  shows Show[]
}

model Show {
  id             Int      @id @default(autoincrement())
  movieId        Int
  theatreId      Int
  startTime      DateTime
  totalSeats     Int
  showType       String
  regularPrice   Float
  hasGoldenSeats Boolean  @default(false)
  goldenSeats    Int?
  goldenPrice    Float?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  // ✅ Cascade: deleting Movie or Theatre deletes their Shows
  movie   Movie   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  theatre Theatre @relation(fields: [theatreId], references: [id], onDelete: Cascade)

  seats    ShowSeat[]
  bookings Booking[]
}

model ShowSeat {
  id               Int        @id @default(autoincrement())
  showId           Int
  row              String
  number           Int
  type             SeatType   @default(REGULAR)
  status           SeatStatus @default(AVAILABLE)
  lockedAt         DateTime?
  pendingBookingId Int?

  // ✅ Cascade: deleting Show deletes its seats
  show         Show          @relation(fields: [showId], references: [id], onDelete: Cascade)
  bookingSeats BookingSeat[]

  @@unique([showId, row, number])
  @@index([showId, status])
  @@index([pendingBookingId])
  @@index([lockedAt])
}

model Booking {
  id           Int           @id @default(autoincrement())
  userId       Int
  showId       Int
  status       BookingStatus @default(PENDING)
  paymentType  PaymentType   @default(CARD)
  totalAmount  Float?
  paymentId    String?
  refundId     String?
  refundAmount Float?
  cancelledAt  DateTime?
  createdAt    DateTime      @default(now())

  // ✅ Cascade: deleting User deletes their bookings
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  // ✅ Cascade: deleting Show deletes its bookings
  show  Show          @relation(fields: [showId], references: [id], onDelete: Cascade)
  seats BookingSeat[]

  @@index([userId])
  @@index([showId, status])
}

model BookingSeat {
  id         Int      @id @default(autoincrement())
  bookingId  Int
  showSeatId Int
  seatType   SeatType
  seatPrice  Float

  // ✅ Cascade: deleting Booking or ShowSeat deletes BookingSeat
  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  showSeat ShowSeat @relation(fields: [showSeatId], references: [id], onDelete: Cascade)

  @@unique([bookingId, showSeatId])
}
